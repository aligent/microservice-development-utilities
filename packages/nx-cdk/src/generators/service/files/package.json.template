{
  "name": "@services/<%= name %>",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "bundleDependencies": [
    "@libs/infra"
  ],
  "nx": {
    "projectType": "library",
    "tags": [
      "scope:services"
    ],
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vite build --mode ${BUNDLE_MODE:-development}",
          "color": true,
          "cwd": "{projectRoot}"
        }
      }
    }
  }
}
