{
  "author": "Aligent",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "nx affected -t test --coverage",
    "test:all": "nx run-many -t test --coverage",
    "lint": "nx affected -t lint",
    "lint:all": "nx run-many -t lint",
    "typecheck": "nx affected -t typecheck",
    "typecheck:all": "nx run-many -t typecheck",
    "audit": "nx run-many -t lint typecheck test --configuration coverage --skip-nx-cache",
    "pg:synth": "nx run application:pg:synth --mode=development --profile playground",
    "pg:deploy": "nx run application:pg:deploy --mode=development --method=direct --require-approval never --profile playground",
    "pg:diff": "nx run application:pg:diff --mode=development --profile playground",
    "pg:destroy": "nx run application:pg:destroy --mode=development --profile playground",
    "postinstall": "[ -d .git ] && git config core.hooksPath '.git-hooks' && chmod +x .git-hooks/* || true"
  },
  "dependencies": {
    "@aligent/microservice-util-lib": "^1.2.0"
  },
  "devDependencies": {
    "@aligent/cdk-aspects": "^0.5.5",
    "@aligent/cdk-nodejs-function-from-entry": "^0.2.1",
    "@aligent/cdk-step-function-from-file": "^0.5.1",
    "@aligent/nx-openapi": "^2.1.1",
    "@aligent/ts-code-standards": "^4.2.1",
    "@nx/eslint": "22.7.3",
    "@nx/eslint-plugin": "22.7.3",
    "@nx/js": "22.7.3",
    "@nx/vite": "22.7.3",
    "@nx/workspace": "22.7.3",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.21",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^24",
    "@typescript-eslint/eslint-plugin": "8.44.0",
    "@typescript-eslint/parser": "8.44.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "aws-cdk": "^2.1120.0",
    "aws-cdk-lib": "^2.251.0",
    "cdk-nag": "^2.38.2",
    "constructs": "^10.6.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "jiti": "^2.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "nx": "22.7.3",
    "prettier": "^3.8.3",
    "tslib": "^2.8.1",
    "tsx": "^4.22.3",
    "typescript": "~5.9.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "nx": {
    "includedScripts": []
  },
  "workspaces": [
    "application",
    "clients",
    "libs/*",
    "services/*"
  ],
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
