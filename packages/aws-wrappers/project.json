{
    "name": "aws-wrappers",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "library",
    "sourceRoot": "packages/aws-wrappers/src",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "outputs": ["{projectRoot}/dist"],
            "inputs": ["production", "^production"],
            "cache": true,
            "dependsOn": ["^typedoc"],
            "options": {
                "cwd": "{projectRoot}",
                "parallel": false,
                "commands": [
                    "rm -rf dist",
                    "tsc -p tsconfig.lib.cjs.json",
                    "tsc -p tsconfig.lib.esm.json",
                    "node -e \"require('fs').writeFileSync('dist/esm/package.json', JSON.stringify({type:'module'}))\"",
                    "node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'}))\"",
                    "cp package.json dist/package.json",
                    "cp README.md dist/README.md",
                    "cp CLAUDE.md dist/CLAUDE.md",
                    "cp -R docs dist/docs"
                ]
            }
        },
        "typedoc": {
            "executor": "nx:run-commands",
            "options": {
                "cwd": "{projectRoot}",
                "color": true,
                "command": "typedoc --options ./typedoc.config.mjs"
            }
        },
        "nx-release-publish": {
            "options": {
                "packageRoot": "{projectRoot}/dist"
            }
        }
    },
    "tags": ["library"]
}
