{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "rootDir": "src",
        "outDir": "dist/esm",
        "tsBuildInfoFile": "dist/esm/.tsbuildinfo",
        "declaration": true,
        "composite": false,
        "types": ["node"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts", "vitest.config.mjs"]
}
